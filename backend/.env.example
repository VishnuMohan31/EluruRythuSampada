# Application Settings
APP_NAME=Tribes India Marketplace
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/tribes_india_db
DB_ECHO=False

# JWT Settings
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# AWS S3
AWS_REGION=ap-south-1
S3_BUCKET_IMAGES=tribes-india-images
S3_BUCKET_BACKUPS=tribes-india-backups
# Leave empty to use IAM role (recommended for production)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Email Settings (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@tribesindiamarketplace.com
SMTP_FROM_NAME=Tribes India Marketplace

# CAPTCHA (Google reCAPTCHA)
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# Rate Limiting
RATE_LIMIT_ENABLED=True
CONTACT_VENDOR_RATE_LIMIT=10  # per hour per IP
LOGIN_RATE_LIMIT=5  # per 15 minutes per IP

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_ALLOW_CREDENTIALS=True

# File Upload
MAX_IMAGE_SIZE_MB=5
ALLOWED_IMAGE_FORMATS=jpg,jpeg,png,webp

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Backup
BACKUP_RETENTION_COUNT=5
