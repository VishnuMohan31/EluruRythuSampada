# Application
APP_NAME=Eluru Rythu Sampada - Farmers Marketplace
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8004

# Database
DATABASE_URL=postgresql://farmers_user:farmers_password_123@localhost:5434/farmers_marketplace
DB_ECHO=False

# JWT
SECRET_KEY=your-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=180
REFRESH_TOKEN_EXPIRE_DAYS=7

# AWS S3
AWS_REGION=ap-south-1
S3_BUCKET_IMAGES=farmers-marketplace-images
S3_BUCKET_BACKUPS=farmers-marketplace-backups
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@elururythusampada.gov.in
SMTP_FROM_NAME=Eluru Rythu Sampada

# CAPTCHA
RECAPTCHA_SECRET_KEY=

# Rate Limiting
RATE_LIMIT_ENABLED=True
CONTACT_VENDOR_RATE_LIMIT=10
LOGIN_RATE_LIMIT=5

# CORS
CORS_ORIGINS=http://localhost:3004
CORS_ALLOW_CREDENTIALS=True

# File Upload
MAX_IMAGE_SIZE_MB=5
ALLOWED_IMAGE_FORMATS=jpg,jpeg,png,webp
STORAGE_PATH=storage

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Backup
BACKUP_RETENTION_COUNT=5
